#!/bin/bash

# Function to display folders and allow user to select one by number or name
function select_folder() {
    echo "Available folders in the current directory (or type 'exit' to quit):"
    
    # List directories only
    dirs=(*)
    for i in "${!dirs[@]}"; do
        echo "$((i + 1)): ${dirs[i]}"
    done

    while true; do
        read -p "Select a folder by number or name: " folder_input

        # Check if input is a number
        if [[ "$folder_input" =~ ^[0-9]+$ ]] && [ "$folder_input" -ge 1 ] && [ "$folder_input" -le "${#dirs[@]}" ]; then
            selected_folder="${dirs[$((folder_input - 1))]}"
            break
        # Check if input is a valid folder name
        elif [[ " ${dirs[@]} " =~ " $folder_input " ]]; then
            selected_folder="$folder_input"
            break
        elif [[ "$folder_input" == "exit" ]]; then
            echo "Exiting the script."
            exit 0
        else
            echo "Invalid selection. Please try again."
        fi
    done

    # Change to the selected folder
    cd "$selected_folder" || exit
}

# Function to display files and allow user to select one by number or name
function select_file() {
    echo "Files in '$selected_folder':"
    files=(*)
    for i in "${!files[@]}"; do
        echo "$((i + 1)): ${files[i]}"
    done

    while true; do
        read -p "Enter the number of the file to upload or the file name: " file_input

        # Check if input is a number
        if [[ "$file_input" =~ ^[0-9]+$ ]] && [ "$file_input" -ge 1 ] && [ "$file_input" -le "${#files[@]}" ]; then
            file_name="${files[$((file_input - 1))]}"
            break
        # Check if input is a valid file name
        elif [[ " ${files[@]} " =~ " $file_input " ]]; then
            file_name="$file_input"
            break
        else
            echo "Invalid file selection. Please try again."
        fi
    done
}

# Check if the current directory is a git repository
if [ ! -d ".git" ]; then
    echo "This script must be run from the root of the git repository."
    exit 1
fi

# Call the folder selection function
select_folder

# Call the file selection function
select_file

# Ask for the commit message
read -p "Enter the commit message: " commit_message

# Stage the specified file for commit (use relative path)
git add "$file_name"

# Check if there are changes to commit
if ! git diff --cached --quiet; then
    # Commit the changes
    git commit -m "$commit_message"
else
    echo "No changes to commit."
    exit 1
fi

# Push to GitHub (assuming you're pushing to the master branch)
git push -uf origin master

echo "File '$file_name' uploaded to GitHub successfully from '$selected_folder'."
