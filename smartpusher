# Function to display folders and allow user to select one
function select_folder() {
    echo "Available folders in the skriptimine directory:"
    # List directories in the current directory
    for dir in */; do
        echo "$dir"
    done

    # Ask user to select a folder
    read -p "Enter the folder you want to upload from: " selected_folder

    # Check if the selected folder exists
    if [ ! -d "$selected_folder" ]; then
        echo "The specified folder does not exist."
        exit 1
    fi

    # Change to the selected folder
    cd "$selected_folder" || exit
}

# Check if the current directory is a git repository
if [ ! -d ".git" ]; then
    echo "This script must be run from the root of the git repository."
    exit 1
fi

# Ask for the directory to upload from
select_folder

# Ask for the file to upload
read -p "Enter the file to upload (with extension): " file_name

# Check if the specified file exists in the directory
if [ ! -f "$file_name" ]; then
    echo "The specified file does not exist in the directory."
    exit 1
fi

# Ask for the commit message
read -p "Enter the commit message: " commit_message

# Add the specified file to git using the relative path
git add "$file_name"

# Commit the changes
git commit -m "$commit_message"

# Push to GitHub using the specified folder and branch
git push -uf origin master

echo "File '$file_name' uploaded to GitHub successfully from $selected_folder"




