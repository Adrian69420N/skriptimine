#!/bin/bash

# Function to display folders and allow user to select one
function select_folder() {
    echo "Available folders in the current directory:"
    
    # List directories only (including hidden directories)
    select dir in */; do
        if [ -d "$dir" ]; then
            selected_folder="$dir"
            break
        else
            echo "Invalid selection. Please try again."
        fi
    done

    # Check if the selected folder exists
    if [ ! -d "$selected_folder" ]; then
        echo "The specified folder does not exist."
        exit 1
    fi

    # Change to the selected folder
    cd "$selected_folder" || exit
}

# Check if the current directory is a git repository
if [ ! -d ".git" ]; then
    echo "This script must be run from the root of the git repository."
    exit 1
fi

# Call the folder selection function
select_folder

# List files in the selected folder
echo "Files in '$selected_folder':"
ls

# Ask for the file to upload
read -p "Enter the file to upload (with extension): " file_name

# Check if the specified file exists
if [ ! -f "$file_name" ]; then
    echo "The specified file does not exist in the directory."
    exit 1
fi

# Ask for the commit message
read -p "Enter the commit message: " commit_message

# Stage the specified file for commit (use relative path)
git add "$file_name"

# Check if there are changes to commit
if ! git diff --cached --quiet; then
    # Commit the changes
    git commit -m "$commit_message"
else
    echo "No changes to commit."
    exit 1
fi

# Push to GitHub (assuming you're pushing to the master branch)
git push -uf skriptimine master

echo "File '$file_name' uploaded to GitHub successfully from '$selected_folder'."
