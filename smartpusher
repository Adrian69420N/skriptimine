#!/bin/bash

# Function to display folders and allow user to select one or more by number or name
function select_folders() {
    echo "Available folders in the current directory (or type 'exit' to quit):"
    
    # List directories only
    dirs=(*)
    for i in "${!dirs[@]}"; do
        echo "$((i + 1)): ${dirs[i]}"
    done

    selected_folders=()
    while true; do
        read -p "Select folders by number or name (comma-separated for multiple, 'all' for all folders): " folder_input

        if [[ "$folder_input" == "exit" ]]; then
            echo "Exiting the script."
            exit 0
        elif [[ "$folder_input" == "all" ]]; then
            selected_folders=("${dirs[@]}")
            break
        else
            IFS=',' read -ra inputs <<< "$folder_input"
            valid=true
            for input in "${inputs[@]}"; do
                input=$(echo "$input" | xargs)  # Trim whitespace
                if [[ "$input" =~ ^[0-9]+$ ]] && [ "$input" -ge 1 ] && [ "$input" -le "${#dirs[@]}" ]; then
                    selected_folders+=("${dirs[$((input - 1))]}")
                elif [[ " ${dirs[@]} " =~ " $input " ]]; then
                    selected_folders+=("$input")
                else
                    echo "Invalid selection: $input"
                    valid=false
                    break
                fi
            done
            if $valid; then
                break
            fi
        fi
    done
}

# Function to display files and allow user to select one or more by number or name
function select_files() {
    echo "Files in '$selected_folder':"
    files=(*)
    for i in "${!files[@]}"; do
        echo "$((i + 1)): ${files[i]}"
    done

    selected_files=()
    while true; do
        read -p "Enter the number of the files to upload or the file names (comma-separated for multiple): " file_input

        IFS=',' read -ra inputs <<< "$file_input"
        valid=true
        for input in "${inputs[@]}"; do
            input=$(echo "$input" | xargs)  # Trim whitespace
            if [[ "$input" =~ ^[0-9]+$ ]] && [ "$input" -ge 1 ] && [ "$input" -le "${#files[@]}" ]; then
                selected_files+=("${files[$((input - 1))]}")
            elif [[ " ${files[@]} " =~ " $input " ]]; then
                selected_files+=("$input")
            else
                echo "Invalid file selection: $input"
                valid=false
                break
            fi
        done
        if $valid; then
            break
        fi
    done
}

# Check if the current directory is a git repository
if [ ! -d ".git" ]; then
    echo "This script must be run from the root of the git repository."
    exit 1
fi

# Call the folder selection function
select_folders

# Iterate over selected folders
for selected_folder in "${selected_folders[@]}"; do
    cd "$selected_folder" || exit

    # Call the file selection function
    select_files

    # Ask for the commit message
    read -p "Enter the commit message: " commit_message

    # Stage the specified files for commit (use relative path)
    for file_name in "${selected_files[@]}"; do
        git add "$file_name"
    done

    # Check if there are changes to commit
    if ! git diff --cached --quiet; then
        # Commit the changes
        git commit -m "$commit_message"
    else
        echo "No changes to commit in folder '$selected_folder'."
    fi

    cd - || exit
done

# Push to GitHub (assuming you're pushing to the master branch)
git push -uf origin master

echo "Files uploaded to GitHub successfully from selected folders."
